# Alibaba Cloud DashScope API Key (for Qwen models)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragflow_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Model settings (defaults)
EMBEDDING_MODEL=text-embedding-v4
CHAT_MODEL=qwen3.5-plus
LIGHT_MODEL=qwen-flash
ENABLE_THINKING=false
AGENTIC_MAX_ROUNDS=3

# Optional: sync GitHub issues (for indexing/Q&A)
GITHUB_ISSUES_ENABLED=false
GITHUB_ISSUES_OWNER=infiniflow
GITHUB_ISSUES_REPO=ragflow
GITHUB_ISSUES_STATE=all
GITHUB_ISSUES_FILENAME=github_issues_ragflow.md
GITHUB_ISSUES_SYNC_HOURS=24
GITHUB_ISSUES_PER_PAGE=100
GITHUB_ISSUES_MAX_PAGES=3
# Optional: improve rate limit for GitHub API
GITHUB_TOKEN=
