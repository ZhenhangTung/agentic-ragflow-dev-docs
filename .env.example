# ── Project Identity ──────────────────────────────────────────────
# Change these to configure for a different documentation library.
PROJECT_NAME=RAGFlow
PROJECT_DESCRIPTION=RAGFlow API documentation (HTTP API and Python SDK references)
# SDK_CLASS_NAMES=["RAGFlow","DataSet","Dataset","Document","Chunk","Chat","Session","Agent","Memory","Ragflow"]

# ── LLM Provider (Alibaba Cloud DashScope) ───────────────────────
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── PostgreSQL connection ────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragflow_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── Model settings (defaults) ───────────────────────────────────
EMBEDDING_MODEL=text-embedding-v4
CHAT_MODEL=qwen3.5-plus
LIGHT_MODEL=qwen-flash
ENABLE_THINKING=false
AGENTIC_MAX_ROUNDS=3

# ── Docs source (change these for a different project) ──────────
# GITHUB_RAW_BASE=https://raw.githubusercontent.com/org/repo/main/docs
# DOC_FILES=["api_reference.md","sdk_reference.md"]
